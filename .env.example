# Copy to .env and fill in real values. NEVER commit .env.
# ScraperAPI keys (https://www.scraperapi.com/). Secondary is used for rotation/fallback.
SCRAPER_API_KEY=
SCRAPER_API_KEY_SECONDARY=

# ── LLM judges for the dataset annotation layer (pipeline/dataset/) ──────────
# Used only by the (deferred) 3-judge LLM-first annotation. Keys load from .env via
# python-dotenv; never hardcode. Independent model FAMILIES are chosen on purpose:
# Cerebras=Llama-3.3-70B, OpenRouter=Qwen-2.5-72B, Mistral=Mistral-Large.
# (Groq-Llama is the SAME model as Cerebras-Llama → not independent; kept only as fallback.)
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
